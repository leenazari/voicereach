export const getServerSideProps: GetServerSideProps = async ({ params }) => {
  const token = params?.token as string
  const calUrl = process.env.NEXT_PUBLIC_CALCOM_URL || 'https://cal.com/lee-nazari-ohfnvf/15min'

  const supabase = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.SUPABASE_SERVICE_ROLE_KEY!
  )

  try {
    const { data: candidate, error } = await supabase
      .from('candidates')
      .select('name, job_title, job_salary, status, voice_note_url, job_id, interview_token, interview_completed_at')
      .eq('interview_token', token)
      .single()

    if (error || !candidate) {
      return { props: { candidate: null, job: null, pack: null, expired: false, notFound: true, jobClosed: false, calUrl } }
    }

    let job = null
    let pack = null

    if (candidate.job_id) {
      const { data: jobData } = await supabase
        .from('jobs')
        .select('title, company, location, salary, description, required_skills, logo_url, sector, status')
        .eq('id', candidate.job_id)
        .single()

      if (jobData) {
        job = jobData

        if (job.status === 'closed') {
          return { props: { candidate: null, job: null, pack: null, expired: false, notFound: false, jobClosed: true, calUrl } }
        }

        const { data: packData } = await supabase
          .from('interview_packs')
          .select('agent_name, questions')
          .eq('job_id', candidate.job_id)
          .eq('status', 'active')
          .single()

        if (packData) {
          pack = {
            agent_name: packData.agent_name || 'Alex',
            question_count: packData.questions?.questions?.length || 6,
            has_pack: true
          }
        }
      }
    }

    return {
      props: {
        candidate: {
          name: candidate.name,
          job_title: candidate.job_title || '',
          job_salary: candidate.job_salary || '',
          voice_note_url: candidate.voice_note_url || '',
          interview_token: candidate.interview_token || token,
          interview_completed_at: candidate.interview_completed_at || null
        },
        job,
        pack: pack || { agent_name: 'Alex', question_count: 6, has_pack: false },
        expired: false,
        notFound: false,
        jobClosed: false,
        calUrl
      }
    }
  } catch {
    return { props: { candidate: null, job: null, pack: null, expired: false, notFound: true, jobClosed: false, calUrl } }
  }
}
